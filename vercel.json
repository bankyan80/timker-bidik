{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "dist/app.cjs",
      "use": "@vercel/node",
      "config": { "includeFiles": ["dist/assets/**", "dist/index.html", "dist/tutwuri.png"] }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "dist/app.cjs" }
  ]
}